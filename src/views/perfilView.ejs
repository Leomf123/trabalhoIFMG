<%- include('./includes/head') %>
<%- include('./includes/nav1') %>

<div class="container py-5">
    <div class="row">
        <div class="col-lg-3"></div>
        <div class="col-lg-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0 text-center">Meu Perfil</h4>
                </div>
                <div class="card-body">
                    
                    <!-- Foto/Avatar do usuário -->
                    <div class="text-center mb-4">
                        <i class="bi bi-person-circle" style="font-size: 5rem; color: #007bff;"></i>
                    </div>

                    <h1 class="text-center mb-4">Seu Marketplace</h1>
                    <p class="text-center lead">Informações do Usuário:</p>

                    <div class="responsive-table">
                        <table class="table table-bordered my-3">
                            <tr>
                                <th width="40%">ID do Usuário:</th>
                                <td><%= usuario.id %></td>
                            </tr>
                            <tr>
                                <th>Nome:</th>
                                <td><%= usuario.nome || 'Não informado' %></td>
                            </tr>
                            <tr>
                                <th>Sobrenome:</th>
                                <td>Carolina</td> <!-- Isso ainda precisa vir do banco -->
                            </tr>
                            <tr>
                                <th>Email:</th>
                                <td><%= usuario.email %></td>
                            </tr>
                            <tr>
                                <th>Telefone:</th>
                                <td>31999999999</td> <!-- Isso ainda precisa vir do banco -->
                            </tr>
                        </table>
                    </div>

                    <div class="d-flex gap-2 justify-content-center mt-4">
                        <a href="/meus-produtos" class="btn btn-primary">
                            <i class="bi bi-box"></i> Meus Produtos
                        </a>
                        <a href="/login/logout" class="btn btn-danger">
                            <i class="bi bi-box-arrow-right"></i> Sair
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3"></div>
    </div>
</div>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<%- include('./includes/footer') %>