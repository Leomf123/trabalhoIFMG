<%- include('./includes/head') %>
<%- include('./includes/nav1') %>

<!-- Banner da Categoria -->
<div class="position-relative mb-5">
    <img src="<%= categoria.imagem %>" 
         alt="<%= categoria.nome %>" 
         class="w-100"
         style="height: 250px; object-fit: cover; filter: brightness(0.7);">
    <div class="position-absolute top-50 start-50 translate-middle text-center text-white">
        <h1 class="display-4 fw-bold"><%= categoria.nome %></h1>
        <p class="lead"><%= categoria.descricao %></p>
    </div>
</div>

<div class="container">
    <!-- Cabeçalho -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Produtos em <%= categoria.nome %></h2>
        <span class="badge bg-primary"><%= produtos.length %> produtos encontrados</span>
    </div>

    <!-- Lista de Produtos -->
    <% if (produtos.length > 0) { %>
        <div class="row g-4">
            <% produtos.forEach(produto => { %>
                <div class="col-md-3 col-sm-6">
                    <div class="card h-100 shadow-sm produto-card">
                        <!-- Imagem do produto (placeholder) -->
                        <div class="card-img-top bg-light text-center py-5">
                            <i class="bi bi-image" style="font-size: 3rem; color: #ccc;"></i>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title"><%= produto.nome %></h5>
                            <p class="card-text text-muted"><%= produto.descricao %></p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="h5 text-primary mb-0">R$ <%= produto.preco.toFixed(2) %></span>
                                <small class="text-muted">por <%= produto.usuario_nome || 'Vendedor' %></small>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-top-0">
                            <button class="btn btn-primary w-100">
                                <i class="bi bi-cart-plus"></i> Ver detalhes
                            </button>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-box" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Nenhum produto encontrado nesta categoria</h4>
            <p>Seja o primeiro a anunciar!</p>
            <% if (usuario) { %>
                <a href="/produtos/adicionar" class="btn btn-primary mt-2">
                    Anunciar Produto
                </a>
            <% } %>
        </div>
    <% } %>
</div>

<style>
    .produto-card {
        transition: transform 0.3s;
        border: none;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    .produto-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.15) !important;
    }
</style>

<%- include('./includes/footer') %>