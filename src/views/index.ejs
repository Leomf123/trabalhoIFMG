<%-include('./includes/head') %>
<%-include('./includes/nav') %>

       <div class="container">
              <div class="row">
                     <div class="col-lg-2"></div>
                     <div class="col-lg-8">
                            <h1 class="text-center">Lojas</h1>
                            
                            <%- include('includes/messages') %>
                            <% if(usuarios.length> 0) { %>
                            <p class="text-center lead">Lojas Cadastradas:</p>
                            <div class="row">
                                          <% usuarios.forEach( usuario=> { %>

                                          <div class="col-md-4 mb-4">
                                                 <div class="card h-100 shadow-sm">
                                                        <div class="card-body">
                                                               <h3 class="card-title"><%= usuario.nomeLoja %></h5>
                                                               <p class="card-text text-muted"><%= usuario.descricaoLoja %></p>
                                                               <p class="card-text text-muted">
                                                               <i> Esta loja pertence a <%= usuario.nome %> </i>
                                                               </p>
                                                        </div>
                                
                                                 </div>
                                          </div>                                          
                                          <% }) %>
                            </div>
                                   <% } else { %>
                                   <div class="alert alert-info text-center py-5">
                    <i class="bi bi-box" style="font-size: 3rem;"></i>
                    <h4 class="mt-3">Ainda não há lojas cadastradas!</h4>
                    <p>Comece fazendo o cadastro de sua loja!</p>
                    <a href="/login/index" class="btn btn-primary mt-2">
                        Adicionar Loja
                    </a>
                </div>
                                   <% } %>
                            </div>
                     <div class="col-lg-2"></div>
              </div>
       </div>

<%-include('./includes/footer') %>
