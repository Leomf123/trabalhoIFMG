<%-include('./includes/head') %>
<%-include('./includes/nav2') %>

<div class="container">
    <div class="row">
        <div class="col-log-2"></div>
         <h1 class="text-center">Cadastrar Novo Usuário</h1>

        <div class="col-log-8 my-3">
            <form action="/usuario/cadastrar" method="post">
                <div class="form-group">
                    <label>Nome</label>
                    <input type="text" class="form-control my-2" name="nome">
                </div>

                <div class="form-group">
                    <label>Sobrenome</label>
                    <input type="text" class="form-control my-2" name="sobrenome">
                </div>

                <div class="form-group">
                    <label>E-mail</label>
                    <input type="email" class="form-control my-2" name="email">
                </div>

                <div class="form-group">
                    <label>Telefone</label>
                    <input type="tel" class="form-control my-2" name="telefone">
                </div>

                <button type="submit" class="btn btn-primary">Cadastrar</button>

            </form>
        </div>
        <div class="col-log-2"></div>
    </div>
</div>

<%-include('./includes/footer') %>
