<%- include('./includes/head') %>
<%- include('./includes/nav') %>

<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>Meus Produtos</h1>
                <a href="/create" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Adicionar Novo Produto
                </a>
            </div>

            <%- include('./includes/messages') %>

            <!-- Lista de Produtos -->
            <% if (produtos && produtos.length > 0) { %>
                <div class="row">
                    <% produtos.forEach(produto => { %>
                        <div class="col-md-4 mb-4">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body">
                                    <h5 class="card-title"><%= produto.name %></h5>
                                    <p class="card-text text-muted"><%= produto.description %></p>
                                    <p class="card-text">
                                        <strong>Preço:</strong> R$ <%= produto.price %>
                                    </p>
                                </div>
                                <div class="card-footer bg-transparent border-top-0">
                                    <div class="btn-group w-100" role="group">
                                        <a href="/produtos/editar/<%= produto.id %>" 
                                            class="btn btn-outline-primary btn-sm w-50">
                                            <i class="bi bi-pencil"></i> Editar
                                        </a>

                                    <form action="/produtos/deletar/<%= produto.id %>" method="POST" class="w-50">
                                        <input type="hidden" name="CSRFToken" value="<%= csrfToken %>">
                                        <button class="btn btn-outline-danger btn-sm w-100" type="submit">
                                            <i class="bi bi-trash"></i> Deletar
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <% }) %>
                </div>
            <% } else { %>
                <div class="alert alert-info text-center py-5">
                    <i class="bi bi-box" style="font-size: 3rem;"></i>
                    <h4 class="mt-3">Você ainda não possui produtos cadastrados</h4>
                    <p>Comece adicionando seu primeiro produto!</p>
                    <a href="/create" class="btn btn-primary mt-2">
                        Adicionar Produto
                    </a>
                </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Bootstrap Icons (opcional, para ícones) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<%- include('./includes/footer') %>