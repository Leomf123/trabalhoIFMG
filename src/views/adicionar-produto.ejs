<%- include('./includes/head') %>
<%- include('./includes/nav1') %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Adicionar Novo Produto</h4>
                </div>
                <div class="card-body">
                    
                    <!-- Mensagens de erro -->
                    <% if (typeof errors !== 'undefined' && errors) { %>
                        <div class="alert alert-danger">
                            <%= errors %>
                        </div>
                    <% } %>

                    <form action="/produtos/adicionar" method="POST">
                        <div class="mb-3">
                            <label for="nome" class="form-label">Nome do Produto *</label>
                            <input type="text" 
                                   class="form-control" 
                                   id="nome" 
                                   name="nome" 
                                   required 
                                   placeholder="Ex: Brownie de Nutella">
                        </div>

                        <div class="mb-3">
                            <label for="descricao" class="form-label">Descrição *</label>
                            <textarea class="form-control" 
                                      id="descricao" 
                                      name="descricao" 
                                      rows="4" 
                                      required 
                                      placeholder="Descreva seu produto..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label for="preco" class="form-label">Preço (R$) *</label>
                            <input type="number" 
                                   class="form-control" 
                                   id="preco" 
                                   name="preco" 
                                   step="0.01" 
                                   min="0.01" 
                                   required 
                                   placeholder="0.00">
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a href="/meus-produtos" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Salvar Produto
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<%- include('./includes/footer') %>