<%- include('./includes/head') %>
<%- include('./includes/nav1') %>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Adicionar Novo Produto</h4>
                </div>
                <div class="card-body">
                    
                    <!-- Mensagens Flash -->
                    <% if (typeof errors !== 'undefined' && errors) { %>
                        <div class="alert alert-danger">
                            <%= errors %>
                        </div>
                    <% } %>

                    <% if (typeof success !== 'undefined' && success) { %>
                        <div class="alert alert-success">
                            <%= success %>
                        </div>
                    <% } %>

                    <form action="/produtos/adicionar" method="POST">
                        <div class="mb-3">
                            <label for="nome" class="form-label">Nome do Produto *</label>
                            <input type="text" class="form-control" id="nome" name="nome" required>
                        </div>

                        <div class="mb-3">
                            <label for="descricao" class="form-label">Descrição *</label>
                            <textarea class="form-control" id="descricao" name="descricao" rows="3" required></textarea>
                        </div>

                        <div class="mb-3">
                            <label for="preco" class="form-label">Preço (R$) *</label>
                            <input type="number" class="form-control" id="preco" name="preco" step="0.01" min="0.01" required>
                        </div>

                        <div class="mb-3">
                            <label for="categoria" class="form-label">Categoria *</label>
                            <select class="form-control" id="categoria" name="categoria" required>
                                <option value="">Selecione uma categoria</option>
                                <% categorias.forEach(categoria => { %>
                                    <option value="<%= categoria %>"><%= categoria %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Salvar Produto</button>
                            <a href="/meus-produtos" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('./includes/footer') %>